---
import Sidebar from '../components/admin/Sidebar.astro';
import '../styles/app.css';

interface Props {
  title?: string;
}

const { title = 'Admin Dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex, nofollow" />
    
    <!-- Professional Admin Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <style is:global>
      html, body, .font-sans, h1, h2, h3, h4, h5, h6 {
        font-family: 'Inter', system-ui, -apple-system, sans-serif !important;
      }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-900 antialiased font-sans flex flex-col lg:flex-row">
    <!-- Mobile Header -->
    <div class="lg:hidden flex items-center justify-between bg-white border-b border-gray-200 p-4 fixed top-0 left-0 right-0 z-30">
      <a href="/admin" class="flex flex-col">
        <span class="font-bold tracking-tight text-xl text-gray-900 leading-none">Admin</span>
      </a>
      <button id="mobile-menu-btn" class="p-2 -mr-2 text-gray-500 hover:text-gray-900">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </button>
    </div>

    <Sidebar />
    
    <!-- Overlay for mobile -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-30 hidden lg:hidden"></div>
    
    <main class="flex-1 lg:ml-64 p-4 sm:p-6 lg:p-8 pt-20 lg:pt-8 w-full overflow-x-hidden">
      <div class="max-w-6xl mx-auto">
        <slot />
      </div>
    </main>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      
      function toggleMenu() {
        sidebar?.classList.toggle('-translate-x-full');
        overlay?.classList.toggle('hidden');
      }

      btn?.addEventListener('click', toggleMenu);
      overlay?.addEventListener('click', toggleMenu);
    </script>
  </body>
</html>
