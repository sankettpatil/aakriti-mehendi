---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  hideNav?: boolean;
  keywords?: string;
}

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/app.css';

const {
  title = 'Aakriti - Bridal Mehndi Artist | Book Your Appointment Online',
  description = 'Aakriti is a professional bridal mehndi artist with 8+ years of experience in intricate, personalised henna designs for weddings, engagements, and special occasions. Book online today.',
  ogImage = 'https://aakriti.in/og-image.jpg',
  canonicalUrl = 'https://aakriti.in/',
  hideNav = false,
  keywords = 'bridal mehndi artist, wedding mehndi artist, bridal henna designs, mehndi artist for wedding, bridal mehndi booking, professional mehndi artist, mehndi artist near me, occasion mehndi, henna artist',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Aakriti Mehndi Artist" />
    <meta name="language" content="English" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Aakriti Bridal Mehndi Artist - intricate henna designs for weddings and special occasions" />
    <meta property="og:site_name" content="Aakriti Mehndi Artist" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <slot name="head" />
  </head>
  <body class="antialiased min-h-screen bg-bg text-ink relative selection:bg-brand selection:text-white">
    {/* Global Grain Texture for Premium Depth */}
    <div class="pointer-events-none fixed inset-0 z-[9999] opacity-[0.03] mix-blend-multiply" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    {!hideNav && <Header />}
    <main>
      <slot />
    </main>
    {!hideNav && <Footer />}
  </body>
</html>
