---
import Layout from '../layouts/Layout.astro';
import { BookingStatusClient } from '../components/status/BookingStatusClient';
---

<Layout title="Check Booking Status | Aakriti Mehndi" description="Check the status of your Mehndi booking request.">
  <main class="min-h-[80vh] flex items-center justify-center py-20 px-4 bg-bg relative overflow-hidden">
    
    {/* Abstract luxury background elements */}
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#982820]/5 rounded-full blur-[100px] pointer-events-none -z-10 translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-[800px] h-[800px] bg-[#982820]/5 rounded-full blur-[120px] pointer-events-none -z-10 -translate-x-1/2 translate-y-1/3"></div>

    <BookingStatusClient client:load />

  </main>
</Layout>
