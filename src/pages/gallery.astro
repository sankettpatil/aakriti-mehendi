---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/home/FinalCTA.astro';
import { Reveal } from '../components/ui/Reveal';

const galleryItems = [
  { src: '/images/mehndi-design-1.png', alt: 'Rajasthani bridal mehndi', style: 'bridal', label: 'Bridal' },
  { src: '/images/mehndi-design-2.png', alt: 'Arabic floral mehndi', style: 'arabic', label: 'Arabic' },
  { src: '/images/mehndi-design-3.png', alt: 'Bridal feet mehndi', style: 'minimalist', label: 'Feet' },
  { src: '/images/mehndi-design-4.png', alt: 'Peacock bridal mehndi', style: 'bridal', label: 'Bridal' },
  { src: '/images/hero-mehndi.png', alt: 'Traditional Rajasthani', style: 'rajasthani', label: 'Rajasthani' },
  { src: '/images/artist-candid.png', alt: 'Minimalist mehndi', style: 'minimalist', label: 'Minimalist' },
  { src: '/images/mehndi-design-1.png', alt: 'Party mehndi design', style: 'party', label: 'Party' },
  { src: '/images/mehndi-design-2.png', alt: 'Arabic design close-up', style: 'arabic', label: 'Arabic' },
  { src: '/images/mehndi-design-4.png', alt: 'Intricate bridal work', style: 'bridal', label: 'Bridal' },
];

const filters = [
  { id: 'all', label: 'All Work' },
  { id: 'bridal', label: 'Bridal' },
  { id: 'arabic', label: 'Arabic' },
  { id: 'rajasthani', label: 'Rajasthani' },
  { id: 'party', label: 'Occasion' },
  { id: 'minimalist', label: 'Minimalist' }
];
---

<Layout
  title="Gallery - Aakriti Mehndi Artist"
  description="Browse our portfolio of bridal mehndi, Arabic, Rajasthani, and minimalist henna designs."
>
  {/* Hero Section */}
  <section class="pt-32 pb-16 md:pt-48 md:pb-24 bg-bg relative overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-6 text-center">
      <Reveal client:load>
        <p class="font-body text-[10px] md:text-xs uppercase tracking-[0.4em] text-brand mb-6 md:mb-8">Portfolio</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-[90px] leading-[1.1] font-normal tracking-tight text-ink mb-8">
          Our <span class="italic text-ink/40">Artistry.</span>
        </h1>
        <p class="font-body text-ink-muted text-base md:text-[17px] max-w-2xl mx-auto leading-relaxed font-light">
          Every stroke is an heirloom. Browse through our curated collection of bridal, occasion, and contemporary mehndi art.
        </p>
      </Reveal>
    </div>
  </section>

  {/* Gallery Body */}
  <section class="pb-32 bg-bg min-h-screen">
    <div class="max-w-[1400px] mx-auto px-6">
      
      {/* Sticky Filters */}
      <Reveal client:load delay={0.2}>
        <div class="flex flex-wrap justify-center gap-6 md:gap-12 mb-16 md:mb-24 sticky top-[72px] z-30 bg-bg/90 backdrop-blur-xl py-6 border-b border-border/40" id="gallery-filters">
          {filters.map((filter, i) => (
            <button 
              class={`gallery-filter font-body text-[10px] md:text-[11px] uppercase tracking-[0.2em] transition-all duration-500 pb-1 border-b ${i === 0 ? 'text-ink border-ink' : 'text-ink/40 border-transparent hover:text-ink hover:border-ink/30'}`}
              data-filter={filter.id}
            >
              {filter.label}
            </button>
          ))}
        </div>
      </Reveal>

      {/* Masonry Grid */}
      <Reveal client:load delay={0.3}>
        <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 md:gap-8 space-y-6 md:space-y-8" id="gallery-grid">
          {galleryItems.map((item, index) => (
            <div class="gallery-item break-inside-avoid relative group cursor-pointer" data-style={item.style}>
              <div class="rounded-3xl md:rounded-[32px] overflow-hidden relative shadow-sm">
                <img 
                  src={item.src} 
                  alt={item.alt} 
                  class="w-full h-auto transform transition-transform duration-[2s] group-hover:scale-105" 
                  loading="lazy" 
                />
                {/* Elegant dark overlay on hover */}
                <div class="absolute inset-0 bg-ink/40 opacity-0 group-hover:opacity-100 transition-opacity duration-700 flex items-center justify-center">
                  <span class="font-body text-[10px] text-white uppercase tracking-[0.3em] border border-white/30 px-6 py-3 rounded-full backdrop-blur-sm">
                    View
                  </span>
                </div>
                {/* Style tag */}
                <div class="absolute bottom-6 left-6 opacity-0 group-hover:opacity-100 transition-opacity duration-700 delay-100">
                  <span class="font-display italic text-white text-xl md:text-2xl drop-shadow-md">
                    {item.label}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Reveal>

      {/* Load More */}
      <div class="text-center mt-24">
        <button class="inline-flex items-center gap-4 text-ink font-body text-[11px] tracking-[0.2em] uppercase hover:text-brand transition-colors">
          Load More
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M12 5V19M12 19L5 12M12 19L19 12" stroke-linecap="square"/>
          </svg>
        </button>
      </div>

    </div>
  </section>

  {/* Lightbox Overlay */}
  <div class="lightbox fixed inset-0 z-[200] bg-[#0a0a0a]/95 backdrop-blur-2xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500" id="lightbox" aria-hidden="true">
    
    <button class="absolute top-8 right-8 text-white/50 hover:text-white transition-colors p-2" id="lightbox-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    
    <button class="absolute left-8 text-white/50 hover:text-white transition-colors p-4 hidden md:block" id="lightbox-prev" aria-label="Previous">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    
    <button class="absolute right-8 text-white/50 hover:text-white transition-colors p-4 hidden md:block" id="lightbox-next" aria-label="Next">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <div class="max-w-[90vw] max-h-[85vh] flex flex-col items-center">
      <img class="max-w-[90vw] max-h-[75vh] object-contain rounded-xl shadow-2xl" id="lightbox-image" src="" alt="" />
      <div class="mt-8 text-center">
        <span class="font-display italic text-white/80 text-2xl" id="lightbox-style"></span>
      </div>
    </div>
  </div>

  <FinalCTA />
</Layout>

<script>
  // Filter functionality
  const filters = document.querySelectorAll('.gallery-filter');
  const items = document.querySelectorAll('.gallery-item');

  filters.forEach(filter => {
    filter.addEventListener('click', () => {
      // Reset all filters
      filters.forEach(f => {
        f.classList.remove('text-ink', 'border-ink');
        f.classList.add('text-ink/40', 'border-transparent');
      });
      // Activate clicked
      filter.classList.add('text-ink', 'border-ink');
      filter.classList.remove('text-ink/40', 'border-transparent');

      const filterValue = filter.getAttribute('data-filter');

      items.forEach(item => {
        if (filterValue === 'all' || item.getAttribute('data-style') === filterValue) {
          (item as HTMLElement).style.display = 'block';
          // Force layout recalculation for masonry
          setTimeout(() => { (item as HTMLElement).style.opacity = '1'; }, 50);
        } else {
          (item as HTMLElement).style.display = 'none';
          (item as HTMLElement).style.opacity = '0';
        }
      });
    });
  });

  // Lightbox functionality
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
  const lightboxStyle = document.getElementById('lightbox-style');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');

  let currentIndex = 0;
  const visibleItems = () => Array.from(items).filter(item => (item as HTMLElement).style.display !== 'none');

  function openLightbox(index: number) {
    const visible = visibleItems();
    if (index < 0 || index >= visible.length) return;
    currentIndex = index;

    const img = visible[index].querySelector('img') as HTMLImageElement;
    const tag = visible[index].querySelector('.font-display');

    if (lightboxImage) lightboxImage.src = img.src;
    if (lightboxImage) lightboxImage.alt = img.alt;
    if (lightboxStyle && tag) lightboxStyle.textContent = tag.textContent;
    
    if (lightbox) {
      lightbox.classList.remove('opacity-0', 'pointer-events-none');
      lightbox.setAttribute('aria-hidden', 'false');
    }
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (lightbox) {
      lightbox.classList.add('opacity-0', 'pointer-events-none');
      lightbox.setAttribute('aria-hidden', 'true');
    }
    document.body.style.overflow = '';
  }

  items.forEach((item, _) => {
    item.addEventListener('click', () => {
      const visible = visibleItems();
      const idx = visible.indexOf(item);
      openLightbox(idx);
    });
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxPrev?.addEventListener('click', () => openLightbox(currentIndex - 1));
  lightboxNext?.addEventListener('click', () => openLightbox(currentIndex + 1));

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.classList.contains('pointer-events-none')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') openLightbox(currentIndex - 1);
    if (e.key === 'ArrowRight') openLightbox(currentIndex + 1);
  });

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
</script>
