---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - Aakriti Mehndi Artist" description="The page you are looking for does not exist.">
  <div class="min-h-screen bg-bg flex flex-col items-center justify-center text-center px-6">
    <h1 class="font-display text-8xl md:text-[120px] text-brand/20 font-light mb-4">404</h1>
    <h2 class="font-display text-3xl md:text-5xl text-ink mb-6">Page Not Found</h2>
    <p class="font-body text-[16px] text-ink-muted mb-12 max-w-md">
      We couldn't find the page you were looking for. It might have been moved or doesn't exist.
    </p>
    <a href="/" class="inline-flex bg-ink text-white font-body text-[12px] tracking-[0.2em] uppercase px-10 py-4 rounded-full hover:bg-brand transition-colors">
      Return Home
    </a>
  </div>
</Layout>
