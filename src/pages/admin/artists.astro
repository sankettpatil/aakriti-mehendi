---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { ArtistManager } from '../../components/admin/ArtistManager';
import { getDB, getAllArtists } from '../../lib/db';

const db = getDB(Astro.locals);
const artists = await getAllArtists(db);
---

<AdminLayout title="Artists | Aakriti Admin">
  <div class="mb-8">
    <h1 class="font-bold tracking-tight text-4xl text-gray-900">Artists Roster</h1>
    <p class="text-gray-500 text-base mt-2">Manage the talented mehndi artists available for bookings.</p>
  </div>

  <ArtistManager client:load initialArtists={artists} />
</AdminLayout>
