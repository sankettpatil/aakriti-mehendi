---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { GalleryManager } from '../../components/admin/GalleryManager';
import { getDB } from '../../lib/db';

const db = getDB(Astro.locals);

// Fetch initial data
const { results: images } = await db.prepare(
  'SELECT * FROM gallery_images ORDER BY display_order ASC, created_at DESC'
).all();
---

<AdminLayout title="Gallery | Aakriti Admin">
  <div class="mb-8">
    <h1 class="font-bold tracking-tight text-4xl text-gray-900">Gallery Manager</h1>
    <p class="text-gray-500 text-base mt-2">Upload and manage images displayed in your public portfolio.</p>
  </div>

  <GalleryManager client:load initialImages={images as any} />
</AdminLayout>
