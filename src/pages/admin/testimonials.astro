---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { TestimonialsManager } from '../../components/admin/TestimonialsManager';
import { getDB } from '../../lib/db';

const db = getDB(Astro.locals);

const { results: testimonials } = await db.prepare(
  'SELECT * FROM testimonials ORDER BY display_order ASC, id DESC'
).all();
---

<AdminLayout title="Testimonials | Aakriti Admin">
  <div class="mb-8">
    <h1 class="font-bold tracking-tight text-4xl text-gray-900">Testimonials Manager</h1>
    <p class="text-gray-500 text-base mt-2">Manage customer reviews displayed on your home page.</p>
  </div>

  <TestimonialsManager client:load initialTestimonials={testimonials as any} />
</AdminLayout>
