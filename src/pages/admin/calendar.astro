---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { AdminCalendar } from '../../components/admin/AdminCalendar';
import { getDB } from '../../lib/db';
import 'react-day-picker/dist/style.css';

const db = getDB(Astro.locals);

// Fetch all active bookings with service names to pass to the calendar
const { results: initialBookings } = await db.prepare(`
  SELECT b.*, s.name as service_name
  FROM bookings b
  LEFT JOIN services s ON b.service_id = s.id
  WHERE b.status IN ('pending', 'confirmed', 'completed')
  ORDER BY b.appointment_date ASC, b.appointment_time ASC
`).all();
---

<AdminLayout title="Calendar | Aakriti Admin">
  <div class="mb-8">
    <h1 class="font-bold tracking-tight text-4xl text-gray-900">Calendar</h1>
    <p class="text-gray-500 text-base mt-2">Visualise your schedule and manage daily appointments.</p>
  </div>

  <AdminCalendar client:only="react" initialBookings={initialBookings as any} />
</AdminLayout>
