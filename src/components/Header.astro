---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="header" id="site-header">
  <div class="header__inner w-full px-4 md:px-8 max-w-none">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Aakriti - Home">
      <span class="header__logo-script">Aakriti</span>
      <span class="header__logo-label">MEHNDI ARTIST</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header__nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['header__nav-link', { 'header__nav-link--active': currentPath === link.href }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Actions (CTA) -->
    <div class="header__actions hidden md:flex items-center justify-end gap-4 justify-self-end">
      <!-- CTA -->
      <a href="/book" class="btn btn-primary btn-sm header__cta-inner">
        Book Now
      </a>

      <!-- Profile Dropdown -->
      <div class="relative">
        <button id="profile-dropdown-btn" class="w-10 h-10 rounded-full bg-bg border border-border flex items-center justify-center text-ink hover:bg-surface transition-colors focus:outline-none focus:ring-2 focus:ring-brand/30" aria-label="Profile Menu" aria-haspopup="true" aria-expanded="false">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </button>
        
        <div id="profile-dropdown-menu" class="absolute right-0 top-full mt-2 w-48 bg-surface border border-border rounded-xl shadow-lg opacity-0 invisible transition-all duration-200 translate-y-[-10px] z-50">
          <div class="p-1.5">
            <a href="/status" class="flex items-center gap-3 w-full px-3 py-2.5 text-[13px] font-body text-ink hover:bg-bg rounded-lg transition-colors font-medium">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink-muted">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              Booking Status
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Hamburger -->
    <button
      class="header__hamburger justify-self-end"
      aria-label="Open menu"
      aria-expanded="false"
      id="menu-toggle"
    >
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__inner">
      <nav class="mobile-menu__nav">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={['mobile-menu__link', { 'mobile-menu__link--active': currentPath === link.href }]}
          >
            {link.label}
          </a>
        ))}
      </nav>
      <a href="/book" class="btn btn-primary btn-lg mobile-menu__cta">
        Book an Appointment
      </a>
      <div class="mobile-menu__social">
        <a href="https://instagram.com/aakriti_mehndi" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://wa.me/919876543210" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    height: 72px;
    transition: all 0.3s ease;
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 100%;
  }

  /* Logo */
  .header__logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    line-height: 1;
  }

  .header__logo-script {
    font-family: var(--font-script);
    font-size: 1.75rem;
    color: var(--color-brand);
    line-height: 1;
  }

  .header__logo-label {
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-top: 1px;
  }

  /* Desktop Nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .header__nav-link {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding: 4px 0;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-brand);
    transition: width 0.3s var(--ease-out);
  }

  .header__nav-link:hover {
    color: var(--color-ink);
  }

  .header__nav-link:hover::after {
    width: 100%;
  }

  .header__nav-link--active {
    color: var(--color-ink);
  }

  .header__nav-link--active::after {
    width: 100%;
    background-color: var(--color-brand);
  }

  /* CTA */
  .header__cta {
    border-radius: var(--radius-sm);
  }

  /* Hamburger */
  .header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 110;
  }

  .header__hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 105;
    background-color: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-menu__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: var(--spacing-3xl);
    padding: var(--spacing-xl);
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .mobile-menu__link {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-menu__link:hover,
  .mobile-menu__link--active {
    color: var(--color-brand);
  }

  .mobile-menu__cta {
    width: 100%;
    max-width: 280px;
    text-align: center;
  }

  .mobile-menu__social {
    display: flex;
    gap: var(--spacing-lg);
    color: var(--color-ink-muted);
  }

  .mobile-menu__social a {
    transition: color 0.2s ease;
  }

  .mobile-menu__social a:hover {
    color: var(--color-brand);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .header__nav,
    .header__actions {
      display: none !important;
    }

    .header__hamburger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';

      // Animate hamburger
      const lines = toggle.querySelectorAll('.header__hamburger-line');
      if (isOpen) {
        (lines[0] as HTMLElement).style.transform = 'rotate(45deg) translate(5px, 5px)';
        (lines[1] as HTMLElement).style.opacity = '0';
        (lines[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(5px, -5px)';
      } else {
        (lines[0] as HTMLElement).style.transform = '';
        (lines[1] as HTMLElement).style.opacity = '1';
        (lines[2] as HTMLElement).style.transform = '';
      }
    });

    // Close on link click
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        const lines = toggle.querySelectorAll('.header__hamburger-line');
        (lines[0] as HTMLElement).style.transform = '';
        (lines[1] as HTMLElement).style.opacity = '1';
        (lines[2] as HTMLElement).style.transform = '';
      });
    });
  }

  // Profile Dropdown Logic
  const profileBtn = document.getElementById('profile-dropdown-btn');
  const profileMenu = document.getElementById('profile-dropdown-menu');

  if (profileBtn && profileMenu) {
    const toggleProfileMenu = (e?: Event) => {
      if (e) e.stopPropagation();
      const isExpanded = profileBtn.getAttribute('aria-expanded') === 'true';
      
      if (isExpanded) {
        profileBtn.setAttribute('aria-expanded', 'false');
        profileMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        profileMenu.classList.add('opacity-0', 'invisible', 'translate-y-[-10px]');
      } else {
        profileBtn.setAttribute('aria-expanded', 'true');
        profileMenu.classList.remove('opacity-0', 'invisible', 'translate-y-[-10px]');
        profileMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
      }
    };

    profileBtn.addEventListener('click', toggleProfileMenu);

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (profileBtn.getAttribute('aria-expanded') === 'true' && !profileBtn.contains(e.target as Node) && !profileMenu.contains(e.target as Node)) {
        toggleProfileMenu();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && profileBtn.getAttribute('aria-expanded') === 'true') {
        toggleProfileMenu();
        profileBtn.focus();
      }
    });
  }
</script>
