---
interface Props {
  eyebrow?: string;
  heading: string;
  subtext?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const {
  eyebrow,
  heading,
  subtext,
  align = 'center',
  light = false,
} = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, { 'section-heading--light': light }]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="section-heading__title">{heading}</h2>
  {subtext && <p class="section-heading__sub">{subtext}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--spacing-3xl);
  }

  .section-heading--center {
    text-align: center;
  }

  .section-heading--left {
    text-align: left;
  }

  .section-heading .eyebrow {
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .section-heading__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .section-heading--light .section-heading__title {
    color: white;
  }

  .section-heading--light .eyebrow {
    color: var(--color-gold);
  }

  .section-heading__sub {
    margin: var(--spacing-md) auto 0;
    max-width: 560px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  .section-heading--left .section-heading__sub {
    margin-left: 0;
  }

  .section-heading--light .section-heading__sub {
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .section-heading__title {
      font-size: 2rem;
    }
  }
</style>
