---
import { Reveal } from '../ui/Reveal';

const cities = [
  'Jaipur', 'Delhi', 'Noida', 'Gurugram', 'Ghaziabad', 'Faridabad', 
  'Lucknow', 'Chandigarh', 'Agra', 'Meerut', 
  'Mathura', 'Haridwar'
];
---

<section class="py-12 md:py-16 bg-bg border-t border-border/40 overflow-hidden">
  <div class="max-w-[1200px] mx-auto px-6 text-center flex flex-col items-center">
    
    <Reveal client:visible>
      <p class="font-body text-[10px] md:text-xs uppercase tracking-[0.4em] text-brand mb-6">Our Reach</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-ink font-normal tracking-tight mb-10 md:mb-16">
        Serving North India
      </h2>
    </Reveal>

    <div class="max-w-5xl mx-auto">
      <Reveal client:visible delay={0.2}>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-4 md:gap-x-12 md:gap-y-8 text-center">
          {cities.map((city, index) => (
            <span class="font-display text-2xl md:text-4xl text-ink/40 hover:text-ink transition-colors duration-700 cursor-default italic">
              {city}
            </span>
          ))}
        </div>
      </Reveal>
    </div>

    <Reveal client:visible delay={0.4}>
      <div class="mt-20 md:mt-32">
        <div class="w-12 h-px bg-border/80 mx-auto mb-8"></div>
        <p class="font-body text-ink-muted text-[13px] font-light tracking-wide">
          Planning an event further away?{' '}
          <a href="mailto:hello@aakriti.com" class="text-ink uppercase text-[10px] tracking-[0.2em] font-medium hover:text-brand transition-colors ml-4 inline-flex items-center gap-2">
            Request Travel
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-linecap="square"/>
            </svg>
          </a>
        </p>
      </div>
    </Reveal>
    
  </div>
</section>
