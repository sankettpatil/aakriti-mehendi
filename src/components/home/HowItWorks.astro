---
import { Reveal } from '../ui/Reveal';

const steps = [
  {
    number: '01',
    title: 'The Consultation',
    description: 'Select your preferred dates and tell us about your vision. We ensure every detail is aligned with your aesthetic before moving forward.',
  },
  {
    number: '02',
    title: 'The Blueprint',
    description: 'Once confirmed, our artists craft a personalized design narrative. We finalize the motifs, flow, and exact timings for your event.',
  },
  {
    number: '03',
    title: 'The Experience',
    description: 'On your special day, sit back and immerse yourself in the moment. We bring the artistry to you, executing flawlessly.',
  },
];
---

<section class="w-full bg-surface py-12 md:py-16 border-t border-border/40">
  <div class="max-w-[1200px] mx-auto px-6">
    
    <Reveal client:visible>
      <div class="text-center mb-12 md:mb-16">
        <p class="font-body text-[10px] md:text-xs uppercase tracking-[0.3em] text-brand mb-6">The Process</p>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-ink font-normal tracking-tight">
          How Booking Works
        </h2>
      </div>
    </Reveal>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border-y border-border/40 divide-y lg:divide-y-0 lg:divide-x divide-border/40">
      {steps.map((step, index) => (
        <Reveal client:visible delay={0.1 * index}>
          <div class="p-8 md:p-12 flex flex-col h-full group hover:bg-bg/50 transition-colors duration-500">
            <span class="font-script text-6xl md:text-7xl text-brand/20 mb-8 block transition-colors duration-500 group-hover:text-brand/40">{step.number}</span>
            <h3 class="font-display text-2xl md:text-3xl text-ink mb-4">{step.title}</h3>
            <p class="font-body text-ink-muted leading-relaxed font-light text-[15px]">
              {step.description}
            </p>
          </div>
        </Reveal>
      ))}
    </div>

    <Reveal client:visible delay={0.4}>
      <div class="mt-12 md:mt-16 text-center">
        <a href="/book" class="inline-flex items-center gap-4 text-ink font-body text-[11px] tracking-[0.2em] uppercase hover:text-brand transition-colors">
          Start Your Booking
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-linecap="square"/>
          </svg>
        </a>
      </div>
    </Reveal>
    
  </div>
</section>
